# -------------------------------------------------------
# INFERENCE PROVIDER
# "huggingface" = production/submission (default)
# "groq"        = local testing (fast, free)
# "nvidia"      = local testing alternative
# -------------------------------------------------------
INFERENCE_PROVIDER=huggingface

# -------------------------------------------------------
# HUGGINGFACE  used for submission
# Get token at: https://huggingface.co/settings/tokens
# -------------------------------------------------------
HF_TOKEN=your_huggingface_token_here
# MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
# API_BASE_URL=https://router.huggingface.co/v1

# -------------------------------------------------------
# GROQ  used for local testing
# Get key at: https://console.groq.com
# -------------------------------------------------------
# INFERENCE_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# MODEL_NAME=moonshotai/kimi-k2-instruct

# -------------------------------------------------------
# NVIDIA NIM  alternative local testing
# Get key at: https://build.nvidia.com
# -------------------------------------------------------
# INFERENCE_PROVIDER=nvidia
# NVIDIA_API_KEY=your_nvidia_key_here
# MODEL_NAME=meta/llama-3.3-70b-instruct

# -------------------------------------------------------
# ENVIRONMENT SERVER
# -------------------------------------------------------
BASE_URL=http://localhost:7860
PORT=7860
